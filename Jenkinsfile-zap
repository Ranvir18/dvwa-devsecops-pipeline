pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('OWASP ZAP Baseline Scan') {
            steps {
                script {
                    sh 'mkdir -p "$WORKSPACE/zap-report"'

                    def zapExitCode = sh(
                        script: '''
                            docker run --rm \
                                --network host \
                                -v "$WORKSPACE/zap-report:/zap/wrk" \
                                ghcr.io/zaproxy/zaproxy:stable \
                                zap-baseline.py \
                                -t http://127.0.0.1:4280 \
                                -r report.html
                        ''',
                        returnStatus: true
                    )

                    echo "OWASP ZAP finished with exit code ${zapExitCode}"

                    if (zapExitCode == 3) {
                        error("OWASP ZAP execution failed.")
                    }
                }
            }
        }
    }

    post {
    always {

        publishHTML(target: [
            allowMissing: false,
            alwaysLinkToLastBuild: true,
            keepAll: true,
            reportDir: 'zap-report',
            reportFiles: 'report.html',
            reportName: 'OWASP ZAP Report'
        ])

        emailext(

            to: "ranvirsh05@gmail.com",

            subject: "[DevSecOps] OWASP ZAP Scan Report | ${env.JOB_NAME} #${env.BUILD_NUMBER}",

            mimeType: 'text/html',

            attachmentsPattern: 'zap-report/report.html',

            body: """
<html>

<body style="font-family:Arial">

<h2>DevSecOps OWASP ZAP Scan Report</h2>

<p>Hello Team,</p>

<p>
The automated OWASP ZAP Dynamic Application Security Testing (DAST)
scan has completed successfully.
</p>

<hr>

<h3>Build Details</h3>

<ul>
<li><b>Project:</b> ${env.JOB_NAME}</li>
<li><b>Build Number:</b> ${env.BUILD_NUMBER}</li>
<li><b>Status:</b> ${currentBuild.currentResult}</li>
</ul>

<hr>

<h3>OWASP ZAP Scan</h3>

<p>
The OWASP ZAP baseline scan has completed successfully.
</p>

<p>
The detailed HTML security report has been attached to this email.
Please review all identified alerts before deployment.
</p>

<br>

Regards,<br>

<b>DevSecOps Team</b>

</body>

</html>
"""
        )
    }
}
}
