pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('OWASP ZAP Baseline Scan') {
            steps {
                script {
                    sh 'mkdir -p "$WORKSPACE/zap-report"'

                    def zapExitCode = sh(
                        script: '''
                            docker run --rm \
                                --network host \
                                -v "$WORKSPACE/zap-report:/zap/wrk" \
                                ghcr.io/zaproxy/zaproxy:stable \
                                zap-baseline.py \
                                -t http://127.0.0.1:4280 \
                                -r report.html
                        ''',
                        returnStatus: true
                    )

                    echo "OWASP ZAP finished with exit code ${zapExitCode}"

                    if (zapExitCode == 3) {
                        error("OWASP ZAP execution failed.")
                    }
                }
            }
        }
    }

    post {
        always {
            publishHTML(target: [
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'zap-report',
                reportFiles: 'report.html',
                reportName: 'OWASP ZAP Report'
            ])
        }
    }
}
